rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidTransaction() {
      let data = request.resource.data;
      return data.keys().hasAll(['clientName', 'workerId', 'amount', 'currency', 'targetCurrency', 'rate', 'totalCUP', 'date', 'ownerId']) &&
             data.clientName is string && data.clientName.size() <= 100 &&
             data.workerId is string && data.workerId.size() <= 100 &&
             data.amount is number && data.amount >= 0 &&
             data.currency is string && data.currency.size() <= 10 &&
             data.targetCurrency is string && data.targetCurrency.size() <= 10 &&
             data.rate is number && data.rate >= 0 &&
             data.totalCUP is number && data.totalCUP >= 0 &&
             data.date is string && data.date.size() <= 50 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 500)) &&
             (!('status' in data) || (data.status is string && data.status.size() <= 50)) &&
             data.ownerId is string && data.ownerId == request.auth.uid;
    }

    function isValidWorker() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'ownerId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('accountInfo' in data) || (data.accountInfo is string && data.accountInfo.size() <= 500)) &&
             data.ownerId is string && data.ownerId == request.auth.uid;
    }

    function isValidSettings() {
      let data = request.resource.data;
      return (!('funds' in data) || data.funds is map) &&
             (!('referenceRates' in data) || data.referenceRates is map) &&
             (!('pairs' in data) || data.pairs is list);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /transactions/{txId} {
      allow read: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow create: if isAuthenticated() && isValidTransaction();
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid && isValidTransaction() && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    match /workers/{workerId} {
      allow read: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow create: if isAuthenticated() && isValidWorker();
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid && isValidWorker() && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    match /settings/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSettings();
      allow update: if isOwner(userId) && isValidSettings();
      allow delete: if isOwner(userId);
    }
  }
}
