{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the user was created."
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Item": {
      "title": "Item",
      "description": "A sample item created by a user.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The item's unique ID."
        },
        "name": {
          "type": "string",
          "description": "The name of the item."
        },
        "ownerId": {
          "type": "string",
          "description": "The ID of the user who owns this item."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the item was created."
        }
      },
      "required": ["name", "ownerId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/items/{itemId}": {
      "schema": {
        "$ref": "#/entities/Item"
      },
      "description": "Stores sample items."
    }
  }
}
