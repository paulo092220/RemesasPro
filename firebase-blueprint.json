{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A remittance transaction.",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "workerId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "targetCurrency": { "type": "string" },
        "rate": { "type": "number" },
        "totalCUP": { "type": "number" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "date": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["clientName", "workerId", "amount", "currency", "targetCurrency", "rate", "totalCUP", "date", "ownerId"]
    },
    "Worker": {
      "title": "Worker",
      "description": "A worker/beneficiary.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "accountInfo": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "ownerId"]
    },
    "Settings": {
      "title": "Settings",
      "description": "User settings (funds, rates, pairs).",
      "type": "object",
      "properties": {
        "funds": { "type": "object" },
        "referenceRates": { "type": "object" },
        "pairs": { "type": "array" }
      }
    }
  },
  "firestore": {
    "/transactions/{txId}": { "schema": { "$ref": "#/entities/Transaction" }, "description": "Transactions" },
    "/workers/{workerId}": { "schema": { "$ref": "#/entities/Worker" }, "description": "Workers" },
    "/settings/{userId}": { "schema": { "$ref": "#/entities/Settings" }, "description": "User settings" }
  }
}
